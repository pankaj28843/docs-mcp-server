{
  "permissions": {
    "allow": [
      "Bash(uv *)",
      "Bash(timeout *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(gh *)",
      "Bash(rg *)",
      "Bash(curl *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(mkdir *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Read(.env*)",
      "Read(.envrc)",
      "Read(deployment.json)",
      "Read(deployment.*.json)"
    ]
  }
}
